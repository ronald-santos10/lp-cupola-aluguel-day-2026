---
import Button from "./Button.astro";
import Text from "./Text.astro";
import data from "../data/data.json";
import cupolaimage from "../assets/cupola-image.webp";

const { about } = data;
---

<section class="bg-black py-20 flex flex-col gap-6">
  <div
    class="container grid items-center gap-10 rounded-tr-[70px] bg-lime p-8 lg:grid-cols-[1fr_0.9fr] md:p-12"
  >
    <div class="flex flex-col gap-5">
      <Text as="h2" variant="h2" color="ink">
        {about.title}
      </Text>
      <Text color="ink">
        {about.description1}
        <br /><br />
        {about.description2}
      </Text>
      <div>
        <Button target="_blank" href={about.href} variant={about.variant}>
          {about.cta}
        </Button>
      </div>
    </div>
    <img src={cupolaimage.src} alt="Imagem do Cupola" class="mx-auto w-full" />
  </div>
  <p
    class="container
    text-center
    font-boldonse
    text-xl
    xl:text-3xl
    uppercase
    text-white"
  >
    {about.taglinePart1}

    {" "}

    <span class="text-lime">
      {about.taglineHighlight1}
    </span>

    {" "}

    {about.taglinePart2}

    {" "}

    <span class="text-lime">
      {about.taglineHighlight2}
    </span>
  </p>
</section>
