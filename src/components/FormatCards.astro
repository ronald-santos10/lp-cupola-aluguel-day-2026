---
import Button from "./Button.astro";
import SectionHeading from "./SectionHeading.astro";
import Text from "./Text.astro";

const { data } = Astro.props;

import backgroundImage from "../assets/bg-blue.webp";
import palestraImg from "../assets/palestras.webp";
import entrevistasImg from "../assets/entrevistas.webp";
import insiderImg from "../assets/espaco-insider.webp";
import networkingImg from "../assets/networking.webp";

const { formats } = data;

const images = {
  palestras: palestraImg,
  entrevistas: entrevistasImg,
  insider: insiderImg,
  networking: networkingImg,
};

type FormatItem = {
  image: string;
  title: string;
  description: { text: string; bold: boolean }[] | string;
};
---

<section
  class="flex flex-col gap-8 bg-blue py-12 lg:py-20"
  style={`
    background-image: url(${backgroundImage.src});
    background-size: cover;
    background-position: center;
  `}
>
  <SectionHeading
    title={formats.title}
    titleColor="white"
    descriptionColor="white"
  />

  <div class="container grid gap-5 md:grid-cols-2">
    {
      formats.items.map((format: FormatItem) => {
        const image = images[format.image as keyof typeof images];

        return (
          <article
            class="
          overflow-hidden
          rounded-3xl
          bg-cream
          shadow-lg/10
          transition-transform
          duration-300
          hover:-translate-y-1
        "
          >
            <img
              src={image.src}
              width={image.width}
              height={image.height}
              alt={format.title}
              class="
            aspect-video
            w-full
            object-cover
          "
            />

            <div class="flex flex-col gap-2 p-5 md:p-6">
              <Text as="h3" color="ink" class="text-xl font-bold leading-tight">
                {format.title}
              </Text>

              <Text as="p" color="muted" class="text-base leading-relaxed">
                {Array.isArray(format.description)
                  ? format.description.map((part) =>
                      part.bold ? <strong>{part.text}</strong> : part.text,
                    )
                  : format.description}
              </Text>
            </div>
          </article>
        );
      })
    }
  </div>

  <div class="text-center">
    <Button>{formats.cta}</Button>
  </div>
</section>
