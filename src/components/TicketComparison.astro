---
import Button from "./Button.astro";
import Text from "./Text.astro";
import data from "../data/data.json";

import liderIcon from "../assets/vectors/lider.svg";
import timeIcon from "../assets/vectors/time.svg";
import comboIcon from "../assets/vectors/combo.svg";

import checkIcon from "../assets/vectors/check.svg";
import noneIcon from "../assets/vectors/none.svg";

const { comparison, tickets } = data;

const icons = {
  lider: liderIcon,
  time: timeIcon,
  combo: comboIcon,
};
---

<section class="bg-cream py-20">
  <div class="container">
    <Text as="h2" variant="h2" color="ink">
      {comparison.title}
    </Text>

    <div class="mt-8 overflow-x-auto">
      <div class="min-w-212.5">
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-line">
              <th class="w-95"></th>

              {
                tickets.items.map((ticket) => {
                  const icon = icons[ticket.vector as keyof typeof icons];

                  return (
                    <th class="py-4 text-center">
                      <div class="flex items-center justify-center gap-2">
                        <img src={icon.src} width="24" height="24" alt="" />

                        <span
                          class:list={[
                            "font-display text-[28px] font-extrabold leading-none",
                            ticket.colorClass,
                          ]}
                        >
                          {ticket.name}
                        </span>
                      </div>

                      <Text
                        as="span"
                        variant="eyebrow"
                        color="ink"
                        class="uppercase"
                      >
                        ({ticket.mode})
                      </Text>
                    </th>
                  );
                })
              }
            </tr>
          </thead>

          <tbody>
            {
              comparison.rows.map((row) => (
                <tr class="border-b border-line">
                  <td class="w-95 py-5 pr-10 text-base">{row.label}</td>

                  {row.values.map((value) => (
                    <td class="py-5 text-center">
                      <img
                        src={value ? checkIcon.src : noneIcon.src}
                        width="20"
                        height="20"
                        alt=""
                        class="mx-auto"
                      />
                    </td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>

        <!-- botões dentro do scroll da tabela -->
        <div
          class="mt-5
          grid
          grid-cols-[380px_repeat(3,1fr)]
          gap-5
          text-white"
        >
          <div></div>

          {
            tickets.items.map((ticket, index) => (
              <Button
                icon={false}
                variant={ticket.variant}
                size="sm"
                href={ticket.href}
              >
                {comparison.buttons[index]}
              </Button>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
