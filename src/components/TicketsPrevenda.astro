---
import liderIcon from "../assets/vectors/lider.svg";
import timeIcon from "../assets/vectors/time.svg";
import comboIcon from "../assets/vectors/combo.svg";
import Button from "./Button.astro";
import SectionHeading from "./SectionHeading.astro";
import Text from "./Text.astro";
import data from "../data/dataPrevenda.json";
import backgroundImage from "../assets/bg-dark-blue.webp";

const { tickets } = data;

const icons = {
  lider: liderIcon,
  time: timeIcon,
  combo: comboIcon,
};
---

<section
  id="ingressos"
  class="bg-navy py-20 flex flex-col gap-6"
  style={`
    background-image: url(${backgroundImage.src});
    background-size: cover;
    background-position: bottom;
  `}
>
  <Text
    as="span"
    variant="eyebrow"
    color="ink"
    class="rounded-full bg-cream px-3 py-1 w-fit mx-auto"
  >
    {tickets.eyebrow}
  </Text>

  <SectionHeading title={tickets.title} titleColor="white" />

  <div class="container grid gap-5 md:grid-cols-3">
    {
      tickets.items.map((ticket) => {
        const Icon = icons[ticket.vector as keyof typeof icons];

        return (
          <article class="rounded-card bg-cream p-6 text-ink">
            <Text as="span" variant="eyebrow" color="ink">
              {ticket.label}
            </Text>

            <hr class="my-2 border-ink/40" />

            <div class="flex items-center gap-2">
              <img src={Icon.src} width={24} height={24} alt="" />

              <h3
                class:list={[
                  "font-display text-[28px] font-extrabold leading-none",
                  ticket.colorClass,
                ]}
              >
                {ticket.name}
              </h3>
            </div>

            <Text as="p" variant="eyebrow" color="ink" class="mt-1 uppercase">
              ({ticket.mode})
            </Text>

            <Text as="p" variant="price" color="ink" class="mt-4">
              {ticket.price}
            </Text>

            <div class="mt-6 text-white">
              <Button
                variant={ticket.variant}
                size="sm"
                class="w-full "
                href={ticket.href}
              >
                {ticket.cta}
              </Button>
            </div>
          </article>
        );
      })
    }
  </div>

  <Text as="p" variant="small" color="white" class="text-center">
    {tickets.obs}
  </Text>
</section>
