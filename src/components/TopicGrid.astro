---
import Button from "./Button.astro";
import SectionHeading from "./SectionHeading.astro";
import Text from "./Text.astro";
import closeIcon from "../assets/vectors/close.svg";

const { data } = Astro.props;
const { market } = data;
---

<section class="bg-cream py-12 lg:py-20">
  <div class="flex flex-col gap-8">
    <SectionHeading title={market.title} titleColor="blue" />

    <div class="container max-w-3xl">
      <div class="grid gap-3 md:grid-cols-2">
        {
          market.items.map((topic: any) => (
            <article
              class="
                flex
                items-center
                gap-3
                rounded-2xl
                bg-red
                px-5
                py-4
                text-white
                shadow-sm
              "
            >
              <div
                class="
                flex
                h-5
                w-5
                shrink-0
                items-center
                justify-center  
              "
              >
                <img
                  src={closeIcon.src}
                  width={20}
                  height={20}
                  alt=""
                  class="h-full w-full object-contain"
                />
              </div>

              <Text
                as="span"
                color="white"
                class="text-sm font-medium leading-snug"
              >
                {topic.title}
              </Text>
            </article>
          ))
        }
      </div>
    </div>

    <Text
      as="p"
      color="ink"
      class="mx-auto max-w-4xl px-4 text-center text-sm md:text-base"
    >
      {market.text}
    </Text>

    <div class="text-center">
      <Button>
        {market.cta}
      </Button>
    </div>
  </div>
</section>
