---
import Button from "./Button.astro";
import SectionHeading from "./SectionHeading.astro";
import Text from "./Text.astro";
const { data } = Astro.props;
import backgroundImage from "../assets/bg-blue.webp";

const { market } = data;
---

<section
  class="py-12 lg:py-20 flex flex-col gap-6"
  style={`
    background-image: url(${backgroundImage.src});
    background-size: cover;
    background-position: bottom;
  `}
>
  <SectionHeading
    title={market.title}
    description={market.description}
    titleColor="white"
    descriptionColor="white"
  />

  <div class="container grid gap-5 md:grid-cols-2">
    {
      market.items.map((topic: { title: unknown; description: unknown; }) => (
        <article class="rounded-card bg-cream p-6 text-ink">
          <Text as="h3" variant="h3" color="ink">
            {topic.title}
          </Text>

          <Text class="mt-4" color="muted">
            {topic.description}
          </Text>
        </article>
      ))
    }
  </div>

  <div class="text-center">
    <Button>{market.cta}</Button>
  </div>
</section>
